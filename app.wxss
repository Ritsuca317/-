page {
  background-color: #f7f8fa;
  color: #333333;
  font-size: 32rpx;
}

.page {
  min-height: 100vh;
  padding: 48rpx 32rpx;
  box-sizing: border-box;
  display: flex;
  justify-content: center;
  align-items: center;
}

.card {
  width: 100%;
  max-width: 680rpx;
  background-color: #ffffff;
  border-radius: 24rpx;
  padding: 48rpx 36rpx;
  box-sizing: border-box;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
  text-align: center;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.4;
}

.subtitle {
  margin-top: 20rpx;
  font-size: 30rpx;
  color: #666666;
  line-height: 1.7;
}

.section {
  margin-top: 40rpx;
  text-align: left;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: #222222;
}

.text {
  display: block;
  font-size: 30rpx;
  color: #555555;
  line-height: 1.8;
}

.value {
  color: #111111;
  font-weight: 600;
}

.input {
  width: 100%;
  height: 88rpx;
  margin-top: 20rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border: 2rpx solid #d9d9d9;
  border-radius: 16rpx;
  background-color: #ffffff;
  text-align: center;
}

.primary-button {
  margin-top: 32rpx;
  background-color: #1677ff;
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 32rpx;
}

.secondary-button {
  margin-top: 20rpx;
  background-color: #f2f3f5;
  color: #333333;
  border-radius: 16rpx;
  font-size: 32rpx;
}

.tip {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #888888;
  line-height: 1.7;
}
